; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LD59"
run/main_scene="uid://cwfllqeqf5iba"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

DragAndDropGroupHelper="*uid://c37ib3yi2l8bc"
GameMaster="*uid://cqjxpe4emtnyo"
CameraSurfManager="*res://addons/LD59Core/camera_surf_manager.gd"
DebugMenu="*uid://cggqb75a8w8r"
SodaAudioManager="*uid://b7hbi78ungg5j"

[display]

window/stretch/scale_mode="integer"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="LD59"

[editor_plugins]

enabled=PackedStringArray("res://addons/DragAndDrop3D/plugin.cfg", "res://addons/LD59Core/plugin.cfg", "res://addons/SodaAudioManager/plugin.cfg", "res://addons/debug_menu/plugin.cfg", "res://addons/dialogue_nodes/plugin.cfg", "res://addons/multipoint_gradient_godot/plugin.cfg")

[file_customization]

folder_colors={
"res://fonts/": "gray",
"res://materials/": "red",
"res://scenes/": "green",
"res://scripting/": "purple",
"res://shaders/": "pink",
"res://subscenes/": "blue",
"res://textures/": "orange"
}

[input]

camera_surf_confirm={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":69,"key_label":0,"unicode":101,"location":0,"echo":false,"script":null)
, Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":0,"position":Vector2(0, 0),"global_position":Vector2(0, 0),"factor":1.0,"button_index":1,"canceled":false,"pressed":false,"double_click":false,"script":null)
]
}

[layer_names]

3d_physics/layer_8="CameraSurfPick"
3d_physics/layer_9="CameraSurfWorldInteract"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
