; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="LD59"
run/main_scene="uid://dqnprgoxue3d7"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

DebugMenu="*uid://cggqb75a8w8r"
DragAndDropGroupHelper="*uid://c37ib3yi2l8bc"
TextureStore="*uid://cyueat2cbprih"
GameMaster="*uid://cqjxpe4emtnyo"

[display]

window/stretch/scale_mode="integer"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="LD59"

[editor_plugins]

enabled=PackedStringArray("res://addons/DragAndDrop3D/plugin.cfg", "res://addons/LD59Core/plugin.cfg", "res://addons/debug_menu/plugin.cfg", "res://addons/dialogue_nodes/plugin.cfg", "res://addons/multipoint_gradient_godot/plugin.cfg")

[file_customization]

folder_colors={
"res://fonts/": "gray",
"res://materials/": "red",
"res://scenes/": "green",
"res://scripting/": "purple",
"res://shaders/": "pink",
"res://subscenes/": "blue",
"res://textures/": "orange"
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
